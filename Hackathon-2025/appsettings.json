{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",

  "ConnectionStrings": {
    "DefaultConnection": "" // 🔑 Key Vault: ConnectionStrings--DefaultConnection
  },

  "Jwt": {
    "Key": "", // 🔑 Key Vault: Jwt--Key
    "Issuer": "HackathonApp",
    "Audience": "HackathonFrontend",
    "ExpiresInMinutes": 60
  },

  "Email": {
    "SmtpHost": "", // Environment Variable: Email__SmtpHost
    "SmtpPort": "", // Environment Variable: Email__SmtpPort
    "SmtpUsername": "", // Environment Variable: Email__SmtpUsername
    "SmtpPassword": "", // 🔑 Key Vault: Email--SmtpPassword
    "FromEmail": "", // Environment Variable: Email__FromEmail
    "FromName": "" // Environment Variable: Email__FromName
  },

  "Feedback": {
    "Recipients": [
      "austintylerdevelopment@gmail.com"
    ],
    "RecipientsCsv": "" // Optional Key Vault override: Feedback--RecipientsCsv
  },

  "Stripe": {
    "PublishableKey": "", // Environment Variable: Stripe__PublishableKey
    "SecretKey": "", // 🔑 Key Vault: Stripe--SecretKey
    "WebhookSecret": "", // 🔑 Key Vault: Stripe--WebhookSecret
    "PriceIdPro": "", // Environment Variable: Stripe__PriceIdPro
    "PriceIdPremium": "", // Environment Variable: Stripe__PriceIdPremium
    "PriceIdAddon5": "", // Environment Variable: Stripe__PriceIdAddon5
    "PriceIdAddon11": "" // Environment Variable: Stripe__PriceIdAddon11
  },

  "Billing": {
    "Provider": "stripe",
    "Pricing": {
      "Free": {
        "Price": "$0/month"
      },
      "Pro": {
        "Price": "$4.99/month"
      },
      "Premium": {
        "Price": "$9.99/month"
      }
    },
    "LaunchSale": {
      "Enabled": true,
      "BadgeText": "Launch Sale",
      "DiscountMode": "forever",
      "DurationInMonths": 1,
      "ProCouponIdForever": "JYT2qnX4", // Stripe coupon id for ongoing Pro discounted renewals
      "ProCouponIdLimited": "6M4hAmm4", // Stripe coupon id for first-month-only Pro discount
      "PremiumCouponIdForever": "AvVW0UJo", // Stripe coupon id for ongoing Premium discounted renewals
      "PremiumCouponIdLimited": "WEW7EVfS", // Stripe coupon id for first-month-only Premium discount
      "ProSalePrice": "$3.99/month",
      "PremiumSalePrice": "$7.99/month"
    }
  },

  "Story": {
    "LengthHintEnabled": false,
    "DefaultParagraphs": 8
  },

  "Sharing": {
    "DefaultExpirationDays": 30
  },

  "ImageGeneration": {
    "ForceSuspiciousImageFailure": false
  },

  "Admin": {
    "Emails": [],
    "EmailsCsv": "" // 🔑 Key Vault: Admin--EmailsCsv
  },

  "Turnstile": {
    "Enabled": true,
    "SiteKey": "", // Optional backend mirror; frontend should use VITE_TURNSTILE_SITE_KEY
    "SecretKey": "" // 🔑 Key Vault: Turnstile--SecretKey
  },

  "Credits": {
    "CarryoverEnabled": true,
    "RequirePremiumForAddons": true,
    "OnlyAllowPurchaseWhenExhausted": true,
    "BaseQuotas": {
      "free": 1,
      "pro": 5,
      "premium": 11
    }
  }
}
